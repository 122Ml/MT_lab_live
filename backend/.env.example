APP_NAME=MT-Lab Live API
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000

HF_LOCAL_FILES_ONLY=true
MODEL_CACHE_DIR=

NMT_ENABLED=true
NMT_MODEL_ZH_EN=../models/opus-mt-zh-en
NMT_MODEL_EN_ZH=../models/opus-mt-en-zh

SMT_ENABLED=true
SMT_MODE=local
SMT_MOSES_ROOT=../../mosesdecoder-master
SMT_MOSES_BIN=
SMT_MODEL_DIR=./smt_model
SMT_DOCKER_IMAGE=moses-smt:latest
SMT_TIMEOUT_SECONDS=60

TRANSFORMER_ENABLED=false
TRANSFORMER_MODEL=../models/nllb-200-distilled-600M

OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_TOKENS=512
OPENAI_RETRIES=2
OPENAI_RETRY_BACKOFF_SECONDS=1.0
