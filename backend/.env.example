APP_NAME=MT-Lab Live API
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000
WARMUP_ON_START=true
WARMUP_TEXT=Warmup sentence for model preload.
WARMUP_SRC_LANG=zh
WARMUP_TGT_LANG=en
RBMT_USE_CEDICT=true
RBMT_CEDICT_PATH=
RBMT_CEDICT_MAX_ENTRIES=300000
RBMT_EN_ZH_TMX_PATH=./data/ebmt/en-zh.tmx
RBMT_TMX_MAX_ENTRIES=200000

HF_LOCAL_FILES_ONLY=true
MODEL_CACHE_DIR=

NMT_ENABLED=true
NMT_MODEL_ZH_EN=../models/opus-mt-zh-en
NMT_MODEL_EN_ZH=../models/opus-mt-en-zh
NMT_EN_ZH_RULES_PATH=./data/nmt_en_zh_rules.tsv

SMT_ENABLED=true
SMT_MODE=auto
SMT_MOSES_ROOT=../../mosesdecoder-master
SMT_MOSES_BIN=
SMT_NIUTRANS_ROOT=../tools/NiuTrans.SMT
SMT_NIUTRANS_BIN=
SMT_NIUTRANS_CONFIG=../tools/NiuTrans.SMT/config/NiuTrans.phrase.config
SMT_MODEL_DIR=./smt_model
SMT_DOCKER_IMAGE=moses-smt:latest
SMT_TIMEOUT_SECONDS=60
SMT_LITE_MODEL_PATH=./smt_model/lite_phrase_table.json
SMT_LITE_SEED_PATH=./data/smt_lite_seed.tsv
SMT_LITE_MAX_CEDICT_ENTRIES=120000

TRANSFORMER_ENABLED=false
TRANSFORMER_MODEL=../models/nllb-200-distilled-600M

OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-4o-mini
OPENAI_AUDIO_MODEL=gpt-4o-mini
OPENAI_VIDEO_MODEL=gpt-4o-mini
OPENAI_TEXT_PROMPT=You are a translation engine. Return only the translated text.
OPENAI_IMAGE_PROMPT=Describe the image briefly and provide a concise translation in target language.
OPENAI_AUDIO_PROMPT=Transcribe and translate the provided audio into target language.
OPENAI_VIDEO_PROMPT=Summarize and translate the key information from the provided video into target language.
OPENAI_MEDIA_MAX_BASE64_CHARS=2000000
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_TOKENS=512
OPENAI_RETRIES=2
OPENAI_RETRY_BACKOFF_SECONDS=1.0
